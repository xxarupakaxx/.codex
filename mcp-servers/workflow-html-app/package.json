{
  "name": "workflow-html-app",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP Apps server for interactive HTML workflow viewers",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build && node scripts/copy-static-ui.mjs",
    "dev": "tsx watch main.ts",
    "test": "node --test test/*.test.js",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dompurify": "^3.2.0",
    "marked": "^15.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
