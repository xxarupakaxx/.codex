prefix_rule(pattern=["/bin/zsh", "-lc", "LOG_FORMAT=plain pnpm -F app env:test test src/scripts/oneshot/grant-mission-progress.test.ts"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "-c", "core.editor=true", "rebase", "--continue"], decision="allow")
prefix_rule(pattern=["git", "commit", "--amend", "--no-edit"], decision="allow")
prefix_rule(pattern=["git", "commit", "--amend", "-m", "docs: /team-run と /pr-watch の監視フローを統合", "-m", "What: /team-run のAgent Teams手順にPJ設定読込とPR継続監視を統合し、/pr-watchのCI/レビュー監視手順とstate lockを追加する。あわせてproject-setupテンプレート、README、project-init、user.example.jsonを同期する。", "-m", "Why: pull時の競合で分岐していたAgent Teams詳細手順とPR監視導線を両立させ、main直pushを避けたブランチ運用でpush可能な状態にするため。", "-m", "Trade-off: /loopはbuilt-in slash commandのため自動起動APIではなく手動実行手順として記載する。Draft PR中はCIのみ監視し、レビュー対応はReady for review後のサイクルに限定する。"], decision="allow")
prefix_rule(pattern=["git", "switch", "-c"], decision="allow")
prefix_rule(pattern=["git", "branch", "-m"], decision="allow")
prefix_rule(pattern=["git", "branch", "-f", "main", "origin/main"], decision="allow")
prefix_rule(pattern=["git", "push", "-u"], decision="allow")
prefix_rule(pattern=["git", "push", "--force-with-lease"], decision="allow")
prefix_rule(pattern=["git", "ls-remote", "--heads", "origin", "fix/0000-team-run-pr-watch-conflict", "feature/0000-team-run-pr-watch-conflict"], decision="allow")
prefix_rule(pattern=["git", "push", "origin", "--delete", "fix/0000-team-run-pr-watch-conflict"], decision="allow")
prefix_rule(pattern=["git", "ls-remote", "--heads", "origin", "feature/0000-team-run-pr-watch-conflict", "fix/0000-team-run-pr-watch-conflict"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["git", "push", "origin"], decision="allow")
prefix_rule(pattern=["git", "ls-remote", "--heads", "origin", "main", "feature/0000-team-run-pr-watch-conflict"], decision="allow")
